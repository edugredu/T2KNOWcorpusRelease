{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "T2KNOW public redacted JSONL record",
  "type": "object",
  "required": [
    "text",
    "entities",
    "meta"
  ],
  "properties": {
    "text": {
      "type": [
        "string",
        "null"
      ]
    },
    "entities": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "start",
          "end",
          "label",
          "text",
          "spans"
        ],
        "properties": {
          "start": {
            "type": "integer",
            "minimum": 0
          },
          "end": {
            "type": "integer",
            "minimum": 0
          },
          "label": {
            "type": "string"
          },
          "text": {
            "type": [
              "string",
              "null"
            ]
          },
          "spans": {
            "type": "array"
          }
        }
      }
    },
    "meta": {
      "type": "object"
    }
  }
}
